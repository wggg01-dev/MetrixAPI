 {
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter ./artifacts/metrix build && pnpm --filter ./artifacts/vaultx build",
  "rewrites": [
    { "source": "/vaultx/:path*", "destination": "/artifacts/vaultx/dist/:path*" },
    { "source": "/(.*)", "destination": "/artifacts/metrix/dist/$1" }
  ]
}